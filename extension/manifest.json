{
  "manifest_version": 3,
  "name": "PasteGuard Web",
  "version": "1.0.0",
  "description": "Privacy-preserving controlled-writing integrity monitor for browser-based assessments.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "PasteGuard Web",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
